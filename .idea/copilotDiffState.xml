&#10;    button:disabled {&#10;      opacity: 0.5;&#10;      cursor: not-allowed;&#10;    }&#10;&#10;    .result {&#10;      margin-top: 32px;&#10;      padding: 28px;&#10;      border-radius: 20px;&#10;      background: rgba(17, 24, 39, 0.5);&#10;      border: 1px solid var(--border);&#10;      backdrop-filter: blur(10px);&#10;      animation: slideIn 300ms ease-out;&#10;      max-width: 600px;&#10;    }&#10;&#10;    @keyframes slideIn {&#10;      from {&#10;        opacity: 0;&#10;        transform: translateY(16px);&#10;      }&#10;      to {&#10;        opacity: 1;&#10;        transform: translateY(0);&#10;      }&#10;    }&#10;&#10;    .result.success {&#10;      border-color: rgba(16, 185, 129, 0.3);&#10;      background: rgba(6, 78, 59, 0.12);&#10;    }&#10;&#10;    .result.error {&#10;      border-color: rgba(220, 38, 38, 0.3);&#10;      background: rgba(127, 29, 29, 0.12);&#10;    }&#10;&#10;    .result h3 {&#10;      margin: 0 0 16px;&#10;      font-size: 0.95rem;&#10;      font-weight: 600;&#10;      text-transform: uppercase;&#10;      letter-spacing: 0.05em;&#10;      color: var(--text-muted);&#10;    }&#10;&#10;    .price {&#10;      font-size: 2.8rem;&#10;      font-weight: 700;&#10;      letter-spacing: -0.02em;&#10;      color: var(--text-primary);&#10;      font-variant-numeric: tabular-nums;&#10;      line-height: 1.1;&#10;    }&#10;&#10;    .price-unit {&#10;      font-size: 0.65em;&#10;      color: var(--text-secondary);&#10;      font-weight: 500;&#10;    }&#10;&#10;    .meta {&#10;      margin-top: 16px;&#10;      padding-top: 16px;&#10;      border-top: 1px solid var(--border);&#10;      font-size: 0.9rem;&#10;      color: var(--text-muted);&#10;    }&#10;&#10;    .meta-row {&#10;      display: flex;&#10;      justify-content: space-between;&#10;      margin: 8px 0;&#10;    }&#10;&#10;    .hint {&#10;      margin-top: 12px;&#10;      padding: 12px 14px;&#10;      border-radius: 10px;&#10;      font-size: 0.85rem;&#10;      color: var(--text-muted);&#10;      background: rgba(37, 99, 235, 0.08);&#10;      border-left: 3px solid var(--accent-primary);&#10;    }&#10;&#10;    .error-detail {&#10;      margin-top: 12px;&#10;      padding: 12px 14px;&#10;      background: rgba(220, 38, 38, 0.1);&#10;      border-left: 3px solid var(--error);&#10;      border-radius: 8px;&#10;      font-size: 0.9rem;&#10;      color: var(--text-secondary);&#10;    }&#10;&#10;    .skeleton {&#10;      background: linear-gradient(&#10;        90deg,&#10;        rgba(255, 255, 255, 0.05) 0%,&#10;        rgba(255, 255, 255, 0.1) 50%,&#10;        rgba(255, 255, 255, 0.05) 100%&#10;      );&#10;      background-size: 200% 100%;&#10;      animation: shimmer 2s infinite;&#10;    }&#10;&#10;    @keyframes shimmer {&#10;      0% { background-position: 200% 0; }&#10;      100% { background-position: -200% 0; }&#10;    }&#10;&#10;    .json-response {&#10;      display: none;&#10;      margin-top: 12px;&#10;      padding: 12px;&#10;      background: #0a0a0a;&#10;      border-radius: 8px;&#10;      border: 1px solid var(--border);&#10;      font-size: 0.8rem;&#10;      color: #cbd5e1;&#10;      overflow: auto;&#10;      max-height: 150px;&#10;    }&#10;&#10;    .json-response.visible {&#10;      display: block;&#10;    }&#10;&#10;    pre {&#10;      margin: 0;&#10;      white-space: pre-wrap;&#10;      word-break: break-word;&#10;      font-family: 'Courier New', monospace;&#10;    }&#10;&#10;    @media (max-width: 768px) {&#10;      h1 { font-size: 2rem; }&#10;      .grid { grid-template-columns: 1fr; gap: 20px; }&#10;      .card { padding: 20px; }&#10;      .price { font-size: 2.2rem; }&#10;      .container { padding: 32px 16px 48px; }&#10;    }&#10;  &lt;/style&gt;&#10;&lt;/head&gt;&#10;&lt;body&gt;&#10;  &lt;main class=&quot;container&quot;&gt;&#10;    &lt;header&gt;&#10;      &lt;h1&gt;Car Price Predictor&lt;/h1&gt;&#10;      &lt;p class=&quot;subtitle&quot;&gt;Machine learning-powered valuation for Japanese used cars. Enter vehicle specifications to get instant predictions.&lt;/p&gt;&#10;    &lt;/header&gt;&#10;&#10;    &lt;div class=&quot;grid&quot;&gt;&#10;      &lt;section class=&quot;card&quot;&gt;&#10;        &lt;h2&gt;Vehicle specifications&lt;/h2&gt;&#10;        &lt;div class=&quot;inline&quot;&gt;&#10;          &lt;label&gt;&#10;            Vehicle age (years)&#10;            &lt;input type=&quot;number&quot; id=&quot;vehicle_age&quot; step=&quot;0.1&quot; min=&quot;0&quot; value=&quot;8.0&quot; /&gt;&#10;          &lt;/label&gt;&#10;          &lt;label&gt;&#10;            Number of doors&#10;            &lt;input type=&quot;number&quot; id=&quot;doors_num&quot; step=&quot;0.1&quot; min=&quot;0&quot; value=&quot;4&quot; /&gt;&#10;          &lt;/label&gt;&#10;        &lt;/div&gt;&#10;        &lt;label&gt;&#10;          Number of seats&#10;          &lt;input type=&quot;number&quot; id=&quot;seats_num&quot; step=&quot;0.1&quot; min=&quot;0&quot; value=&quot;5&quot; /&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Manufacturer&#10;          &lt;select id=&quot;make_clean&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Model name&#10;          &lt;input type=&quot;text&quot; id=&quot;model_clean&quot; value=&quot;Corolla Fielder&quot; /&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Body type&#10;          &lt;select id=&quot;body_guess&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Age category&#10;          &lt;select id=&quot;age_bucket&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;      &lt;/section&gt;&#10;&#10;      &lt;section class=&quot;card&quot;&gt;&#10;        &lt;h2&gt;Market &amp; Location&lt;/h2&gt;&#10;        &lt;label&gt;&#10;          Market country&#10;          &lt;select id=&quot;market_country&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Stock country&#10;          &lt;select id=&quot;stock_country&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Overseas stock&#10;          &lt;select id=&quot;is_overseas_stock&quot;&gt;&#10;            &lt;option value=&quot;false&quot;&gt;Domestic&lt;/option&gt;&#10;            &lt;option value=&quot;true&quot;&gt;International&lt;/option&gt;&#10;          &lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          VIN region&#10;          &lt;select id=&quot;vin_region&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Steering side&#10;          &lt;select id=&quot;steering_group&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;      &lt;/section&gt;&#10;&#10;      &lt;section class=&quot;card&quot;&gt;&#10;        &lt;h2&gt;Powertrain&lt;/h2&gt;&#10;        &lt;label&gt;&#10;          Fuel type&#10;          &lt;select id=&quot;fuel_group&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Transmission&#10;          &lt;select id=&quot;transmission_group&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;label&gt;&#10;          Drive system&#10;          &lt;select id=&quot;drive_group&quot;&gt;&lt;/select&gt;&#10;        &lt;/label&gt;&#10;        &lt;div class=&quot;actions&quot;&gt;&#10;          &lt;button class=&quot;primary&quot; onclick=&quot;predict()&quot;&gt;Get Price Prediction&lt;/button&gt;&#10;          &lt;button class=&quot;secondary&quot; onclick=&quot;fillExample()&quot;&gt;Load example&lt;/button&gt;&#10;        &lt;/div&gt;&#10;        &lt;div class=&quot;hint&quot;&gt; All fields use categories from the training dataset. The model predicts prices in USD.&lt;/div&gt;&#10;      &lt;/section&gt;&#10;    &lt;/div&gt;&#10;&#10;    &lt;section id=&quot;result&quot; class=&quot;result&quot; style=&quot;display:none;&quot;&gt;&lt;/section&gt;&#10;  &lt;/main&gt;&#10;&#10;  &lt;script&gt;&#10;    const API_URL = &quot;/api/v1/predict&quot;;&#10;&#10;    const options = {&#10;      market_country: [&quot;Japan&quot;, &quot;Mozambique&quot;, &quot;Angola&quot;, &quot;Burundi&quot;, &quot;Chile&quot;, &quot;Paraguay&quot;, &quot;Guatemala&quot;, &quot;Costa Rica&quot;, &quot;Dominican Republic&quot;, &quot;Russia&quot;, &quot;Democratic Republic of the Congo&quot;, &quot;Other&quot;],&#10;      stock_country: [&quot;Japan&quot;, &quot;Singapore&quot;, &quot;United Kingdom&quot;, &quot;Australia&quot;, &quot;Other&quot;],&#10;      make_clean: [&quot;TOYOTA&quot;, &quot;NISSAN&quot;, &quot;HONDA&quot;, &quot;MAZDA&quot;, &quot;MITSUBISHI&quot;, &quot;SUZUKI&quot;, &quot;SUBARU&quot;, &quot;ISUZU&quot;, &quot;DAIHATSU&quot;, &quot;LEXUS&quot;, &quot;AUDI&quot;, &quot;BMW&quot;, &quot;CHEVROLET&quot;, &quot;FIAT&quot;, &quot;FORD&quot;, &quot;JAGUAR&quot;, &quot;JEEP&quot;, &quot;LAND ROVER&quot;, &quot;MERCEDES-BENZ&quot;, &quot;MINI&quot;, &quot;PORSCHE&quot;, &quot;RENAULT&quot;, &quot;SMART&quot;, &quot;TESLA&quot;, &quot;VOLKSWAGEN&quot;, &quot;VOLVO&quot;, &quot;ALFA ROMEO&quot;, &quot;AMG&quot;, &quot;HINO&quot;, &quot;PEUGEOT&quot;, &quot;MASERATI&quot;, &quot;Other&quot;],&#10;      age_bucket: [&quot;0-1&quot;, &quot;2-3&quot;, &quot;4-5&quot;, &quot;6-10&quot;, &quot;11-20&quot;, &quot;20+&quot;],&#10;      fuel_group: [&quot;Electric&quot;, &quot;Hybrid(Diesel)&quot;, &quot;Hybrid(Petrol)&quot;, &quot;Diesel&quot;, &quot;Petrol&quot;, &quot;Other&quot;],&#10;      transmission_group: [&quot;CVT&quot;, &quot;Manual&quot;, &quot;Automatic&quot;, &quot;Other&quot;],&#10;      drive_group: [&quot;4WD&quot;, &quot;2WD&quot;, &quot;Other&quot;],&#10;      steering_group: [&quot;Right&quot;, &quot;Left&quot;],&#10;      vin_region: [&quot;Japan&quot;, &quot;Korea&quot;, &quot;United Kingdom&quot;, &quot;Germany&quot;, &quot;USA&quot;, &quot;Canada&quot;, &quot;Mexico&quot;, &quot;China&quot;, &quot;France/Spain&quot;, &quot;Italy&quot;, &quot;Sweden/Finland&quot;, &quot;Other&quot;],&#10;      body_guess: [&quot;truck_pickup&quot;, &quot;van&quot;, &quot;wagon&quot;, &quot;convertible_roadster&quot;, &quot;mpv_minivan&quot;, &quot;coupe_roadster_like&quot;, &quot;sedan_like&quot;, &quot;suv_crossover_like&quot;, &quot;unknown&quot;],&#10;    };&#10;&#10;    function populateSelect(id, values, selectedValue = null) {&#10;      const select = document.getElementById(id);&#10;      select.innerHTML = values.map(v =&gt; `&lt;option value=&quot;${v}&quot;&gt;${v}&lt;/option&gt;`).join(&quot;&quot;);&#10;      if (selectedValue !== null) select.value = selectedValue;&#10;    }&#10;&#10;    function initForm() {&#10;      populateSelect(&quot;market_country&quot;, options.market_country, &quot;Japan&quot;);&#10;      populateSelect(&quot;stock_country&quot;, options.stock_country, &quot;Japan&quot;);&#10;      populateSelect(&quot;make_clean&quot;, options.make_clean, &quot;TOYOTA&quot;);&#10;      populateSelect(&quot;age_bucket&quot;, options.age_bucket, &quot;6-10&quot;);&#10;      populateSelect(&quot;fuel_group&quot;, options.fuel_group, &quot;Petrol&quot;);&#10;      populateSelect(&quot;transmission_group&quot;, options.transmission_group, &quot;Automatic&quot;);&#10;      populateSelect(&quot;drive_group&quot;, options.drive_group, &quot;2WD&quot;);&#10;      populateSelect(&quot;steering_group&quot;, options.steering_group, &quot;Right&quot;);&#10;      populateSelect(&quot;vin_region&quot;, options.vin_region, &quot;Japan&quot;);&#10;      populateSelect(&quot;body_guess&quot;, options.body_guess, &quot;sedan_like&quot;);&#10;    }&#10;&#10;    function fillExample() {&#10;      document.getElementById(&quot;vehicle_age&quot;).value = &quot;8&quot;;&#10;      document.getElementById(&quot;doors_num&quot;).value = &quot;4&quot;;&#10;      document.getElementById(&quot;seats_num&quot;).value = &quot;5&quot;;&#10;      document.getElementById(&quot;make_clean&quot;).value = &quot;TOYOTA&quot;;&#10;      document.getElementById(&quot;model_clean&quot;).value = &quot;Corolla Fielder&quot;;&#10;      document.getElementById(&quot;body_guess&quot;).value = &quot;wagon&quot;;&#10;      document.getElementById(&quot;age_bucket&quot;).value = &quot;6-10&quot;;&#10;      document.getElementById(&quot;market_country&quot;).value = &quot;Japan&quot;;&#10;      document.getElementById(&quot;stock_country&quot;).value = &quot;Japan&quot;;&#10;      document.getElementById(&quot;is_overseas_stock&quot;).value = &quot;false&quot;;&#10;      document.getElementById(&quot;vin_region&quot;).value = &quot;Japan&quot;;&#10;      document.getElementById(&quot;steering_group&quot;).value = &quot;Right&quot;;&#10;      document.getElementById(&quot;fuel_group&quot;).value = &quot;Petrol&quot;;&#10;      document.getElementById(&quot;transmission_group&quot;).value = &quot;Automatic&quot;;&#10;      document.getElementById(&quot;drive_group&quot;).value = &quot;2WD&quot;;&#10;    }&#10;&#10;    function getPayload() {&#10;      return {&#10;        vehicle_age: Number(document.getElementById(&quot;vehicle_age&quot;).value),&#10;        doors_num: Number(document.getElementById(&quot;doors_num&quot;).value),&#10;        seats_num: Number(document.getElementById(&quot;seats_num&quot;).value),&#10;        market_country: document.getElementById(&quot;market_country&quot;).value,&#10;        stock_country: document.getElementById(&quot;stock_country&quot;).value,&#10;        is_overseas_stock: document.getElementById(&quot;is_overseas_stock&quot;).value === &quot;true&quot;,&#10;        make_clean: document.getElementById(&quot;make_clean&quot;).value,&#10;        model_clean: document.getElementById(&quot;model_clean&quot;).value.trim(),&#10;        age_bucket: document.getElementById(&quot;age_bucket&quot;).value,&#10;        fuel_group: document.getElementById(&quot;fuel_group&quot;).value,&#10;        transmission_group: document.getElementById(&quot;transmission_group&quot;).value,&#10;        drive_group: document.getElementById(&quot;drive_group&quot;).value,&#10;        steering_group: document.getElementById(&quot;steering_group&quot;).value,&#10;        vin_region: document.getElementById(&quot;vin_region&quot;).value,&#10;        body_guess: document.getElementById(&quot;body_guess&quot;).value,&#10;      };&#10;    }&#10;&#10;    async function predict() {&#10;      const btn = document.querySelector(&quot;button.primary&quot;);&#10;      const result = document.getElementById(&quot;result&quot;);&#10;      const payload = getPayload();&#10;&#10;      result.style.display = &quot;block&quot;;&#10;      result.className = &quot;result&quot;;&#10;      result.innerHTML = `&#10;        &lt;h3&gt;Calculating&lt;/h3&gt;&#10;        &lt;div class=&quot;skeleton&quot; style=&quot;height: 60px; margin: 16px 0; border-radius: 12px;&quot;&gt;&lt;/div&gt;&#10;        &lt;div class=&quot;skeleton&quot; style=&quot;height: 20px; width: 60%; border-radius: 8px;&quot;&gt;&lt;/div&gt;&#10;      `;&#10;      btn.disabled = true;&#10;&#10;      try {&#10;        const res = await fetch(API_URL, {&#10;          method: &quot;POST&quot;,&#10;          headers: { &quot;Content-Type&quot;: &quot;application/json&quot; },&#10;          body: JSON.stringify(payload),&#10;        });&#10;&#10;        const data = await res.json();&#10;&#10;        if (!res.ok) {&#10;          const errorMsg = Array.isArray(data?.detail)&#10;            ? data.detail.map(e =&gt; e.msg || JSON.stringify(e)).join(&quot;; &quot;)&#10;            : data?.detail || JSON.stringify(data);&#10;          throw new Error(errorMsg);&#10;        }&#10;&#10;        result.className = &quot;result success&quot;;&#10;        const normalPrice = data.predicted_price ?? data.predicted_price_value ?? null;&#10;        const logPrice = data.predicted_price_log ?? null;&#10;&#10;        result.innerHTML = `&#10;          &lt;h3&gt;Estimated Market Value&lt;/h3&gt;&#10;          &lt;div class=&quot;price&quot;&gt;${normalPrice !== null ? Numb